generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id               Int            @id @default(autoincrement())
  nom              String
  prenom           String
  email            String         @unique
  motDePasse       String
  telephone        String?
  role             Role
  createdAt        DateTime       @default(now())
  image            String?
  resetToken       String?        @unique
  resetTokenExpiry DateTime?
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?
  depenses         Depense[]
  employeFermes    EmployeFerme[]
  fermes           Ferme[]
  messagesRecus    Message[]      @relation("MessagesRecus")
  messagesEnvoyes  Message[]      @relation("MessagesEnvoyes")
  notifications    Notification[]
  predictions      Prediction[]
  presences        Presence[]
  revenus          Revenu[]
  traitements      Traitement[]
  vaccinations     Vaccination[]
}

model Ferme {
  id            Int            @id @default(autoincrement())
  nom           String
  adresse       String
  superficie    Float
  createdAt     DateTime       @default(now())
  agriculteurId Int
  depenses      Depense[]
  employes      EmployeFerme[]
  agriculteur   Utilisateur    @relation(fields: [agriculteurId], references: [id])
  predictions   Prediction[]
  revenus       Revenu[]
  terrains      Terrain[]
}

model Terrain {
  id               Int            @id @default(autoincrement())
  nom              String
  superficie       Float
  typeSol          String
  fermeId          Int
  createdAt        DateTime       @default(now())
  localisation     String?
  updatedAt        DateTime       @updatedAt
  latitude         Float?
  longitude        Float?
  animaux          Animal[]
  cultures         Culture[]
  employesAssignes EmployeFerme[]
  ferme            Ferme          @relation(fields: [fermeId], references: [id])
}

model EmployeFerme {
  id                Int              @id @default(autoincrement())
  poste             String
  salaire           Float
  dateEmbauche      DateTime
  employeId         Int
  fermeId           Int
  roleDescription   String?
  terrainAssigneId  Int?
  animauxAssignes   EmployeAnimal[]
  culturesAssignees EmployeCulture[]
  employe           Utilisateur      @relation(fields: [employeId], references: [id])
  ferme             Ferme            @relation(fields: [fermeId], references: [id])
  terrainAssigne    Terrain?         @relation(fields: [terrainAssigneId], references: [id])
}

model EmployeAnimal {
  id             Int          @id @default(autoincrement())
  employeFermeId Int
  animalId       Int
  animal         Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  employeFerme   EmployeFerme @relation(fields: [employeFermeId], references: [id], onDelete: Cascade)

  @@unique([employeFermeId, animalId])
}

model EmployeCulture {
  id             Int          @id @default(autoincrement())
  employeFermeId Int
  cultureId      Int
  culture        Culture      @relation(fields: [cultureId], references: [id], onDelete: Cascade)
  employeFerme   EmployeFerme @relation(fields: [employeFermeId], references: [id], onDelete: Cascade)

  @@unique([employeFermeId, cultureId])
}

model Message {
  id             Int         @id @default(autoincrement())
  contenu        String
  lu             Boolean     @default(false)
  createdAt      DateTime    @default(now())
  expediteurId   Int
  destinataireId Int
  destinataire   Utilisateur @relation("MessagesRecus", fields: [destinataireId], references: [id])
  expediteur     Utilisateur @relation("MessagesEnvoyes", fields: [expediteurId], references: [id])
}

model Categorie {
  id       Int           @id @default(autoincrement())
  nom      String
  type     TypeCategorie
  animaux  Animal[]
  cultures Culture[]
}

model Animal {
  id               Int             @id @default(autoincrement())
  numero           String
  type             String
  race             String
  sexe             Sexe
  poids            Float
  dateNaissance    DateTime
  etatSante        String
  terrainId        Int
  categorieId      Int
  categorie        Categorie       @relation(fields: [categorieId], references: [id])
  terrain          Terrain         @relation(fields: [terrainId], references: [id])
  employesAssignes EmployeAnimal[]
  traitements      Traitement[]
  vaccinations     Vaccination[]
}

model Traitement {
  id            Int         @id @default(autoincrement())
  date          DateTime
  medicament    String
  description   String
  animalId      Int
  veterinaireId Int
  dateFin       DateTime?
  dosage        String?
  observation   String?
  animal        Animal      @relation(fields: [animalId], references: [id])
  veterinaire   Utilisateur @relation(fields: [veterinaireId], references: [id])
}

model Vaccination {
  id               Int         @id @default(autoincrement())
  nomVaccin        String
  dateAdministered DateTime
  dateRappel       DateTime?
  statut           String
  animalId         Int
  veterinaireId    Int
  createdAt        DateTime    @default(now())
  animal           Animal      @relation(fields: [animalId], references: [id])
  veterinaire      Utilisateur @relation(fields: [veterinaireId], references: [id])
}

model Culture {
  id               Int              @id @default(autoincrement())
  nom              String
  datePlantation   DateTime
  quantitePrevue   Float
  etat             String
  terrainId        Int
  categorieId      Int
  categorie        Categorie        @relation(fields: [categorieId], references: [id])
  terrain          Terrain          @relation(fields: [terrainId], references: [id])
  employesAssignes EmployeCulture[]
  recoltes         Recolte[]
}

model Recolte {
  id        Int      @id @default(autoincrement())
  date      DateTime
  quantite  Float
  cultureId Int
  culture   Culture  @relation(fields: [cultureId], references: [id])
}

model Depense {
  id          Int         @id @default(autoincrement())
  date        DateTime
  montant     Float
  type        String
  fermeId     Int
  createdAt   DateTime    @default(now())
  createdById Int
  description String?
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])
  ferme       Ferme       @relation(fields: [fermeId], references: [id])
}

model Revenu {
  id          Int         @id @default(autoincrement())
  date        DateTime
  montant     Float
  source      String
  fermeId     Int
  createdAt   DateTime    @default(now())
  createdById Int
  description String?
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])
  ferme       Ferme       @relation(fields: [fermeId], references: [id])
}

model Prediction {
  id          Int         @id @default(autoincrement())
  type        String
  resultat    String
  date        DateTime    @default(now())
  fermeId     Int
  confiance   Float?
  createdById Int
  conseils    Conseil[]
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])
  ferme       Ferme       @relation(fields: [fermeId], references: [id])
}

model Conseil {
  id           Int        @id @default(autoincrement())
  description  String
  date         DateTime
  predictionId Int
  prediction   Prediction @relation(fields: [predictionId], references: [id])
}

model Notification {
  id            Int                @id @default(autoincrement())
  titre         String
  message       String
  dateEnvoi     DateTime           @default(now())
  statut        StatutNotification
  utilisateurId Int
  utilisateur   Utilisateur        @relation(fields: [utilisateurId], references: [id])
}

model Presence {
  id                Int            @id @default(autoincrement())
  date              DateTime       @default(now())
  statut            StatutPresence
  paye              Boolean        @default(false)
  certificatMedical String?
  utilisateurId     Int
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  utilisateur       Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  AGRICULTEUR
  EMPLOYE
  VETERINAIRE
}

enum TypeCategorie {
  ANIMAL
  CULTURE
}

enum Sexe {
  MALE
  FEMELLE
}

enum StatutNotification {
  LUE
  NON_LUE
}

enum StatutPresence {
  PRESENT
  ABSENT
  MALADE
}
