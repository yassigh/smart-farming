// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGRICULTEUR
  EMPLOYE
  VETERINAIRE
}

enum TypeCategorie {
  ANIMAL
  CULTURE
}

enum Sexe {
  MALE
  FEMELLE
}

enum StatutNotification {
  LUE
  NON_LUE
}

model Utilisateur {
  id               Int      @id @default(autoincrement())
  nom              String
  prenom           String
  email            String   @unique
  motDePasse       String
  telephone        String?
  role             Role
  image            String?  @db.Text
  createdAt        DateTime @default(now())
  
  // 🔐 Champs 2FA et Reset Password
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  resetToken       String?  @unique
  resetTokenExpiry DateTime?
  
  // Relations
  fermes           Ferme[]
  notifications    Notification[]
  traitements      Traitement[]
  vaccinations     Vaccination[]
  employeFermes    EmployeFerme[]
  depenses         Depense[]
  revenus          Revenu[]
  predictions      Prediction[]
  presences        Presence[]
}

model Ferme {
  id         Int      @id @default(autoincrement())
  nom        String
  adresse    String
  superficie Float
  createdAt  DateTime @default(now())

  agriculteurId Int
  agriculteur   Utilisateur @relation(fields: [agriculteurId], references: [id])

  terrains    Terrain[]
  employes    EmployeFerme[]
  depenses    Depense[]
  revenus     Revenu[]
  predictions Prediction[]
}

model Terrain {
  id            Int      @id @default(autoincrement())
  nom           String
  superficie    Float
  typeSol       String

  localisation  String?
  latitude      Float?
  longitude     Float?

  fermeId       Int
  ferme         Ferme @relation(fields: [fermeId], references: [id])

  animaux       Animal[]
  cultures      Culture[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployeFerme {
  id           Int      @id @default(autoincrement())
  poste        String
  salaire      Float
  dateEmbauche DateTime

  employeId Int
  employe   Utilisateur @relation(fields: [employeId], references: [id])

  fermeId Int
  ferme   Ferme @relation(fields: [fermeId], references: [id])
}

model Categorie {
  id   Int           @id @default(autoincrement())
  nom  String
  type TypeCategorie

  animaux  Animal[]
  cultures Culture[]
}

model Animal {
  id            Int      @id @default(autoincrement())
  numero        String
  type          String
  race          String
  sexe          Sexe
  poids         Float
  dateNaissance DateTime
  etatSante     String

  terrainId Int
  terrain   Terrain @relation(fields: [terrainId], references: [id])

  categorieId Int
  categorie   Categorie @relation(fields: [categorieId], references: [id])

  traitements  Traitement[]
  vaccinations Vaccination[]
}

model Traitement {
  id          Int      @id @default(autoincrement())
  date        DateTime
  dateFin     DateTime?
  medicament  String
  description String
  dosage      String?
  observation String?

  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])

  veterinaireId Int
  veterinaire   Utilisateur @relation(fields: [veterinaireId], references: [id])
}

model Vaccination {
  id               Int      @id @default(autoincrement())
  nomVaccin        String
  dateAdministered DateTime
  dateRappel       DateTime?
  statut           String   // e.g. "A_JOUR" or "EN_RETARD"

  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])

  veterinaireId Int
  veterinaire   Utilisateur @relation(fields: [veterinaireId], references: [id])

  createdAt DateTime @default(now())
}

model Culture {
  id             Int      @id @default(autoincrement())
  nom            String
  datePlantation DateTime
  quantitePrevue Float
  etat           String

  terrainId Int
  terrain   Terrain @relation(fields: [terrainId], references: [id])

  categorieId Int
  categorie   Categorie @relation(fields: [categorieId], references: [id])

  recoltes Recolte[]
}

model Recolte {
  id       Int      @id @default(autoincrement())
  date     DateTime
  quantite Float

  cultureId Int
  culture   Culture @relation(fields: [cultureId], references: [id])
}

model Depense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  montant     Float
  type        String
  description String?
  createdAt   DateTime @default(now())

  fermeId Int
  ferme   Ferme @relation(fields: [fermeId], references: [id])

  createdById Int
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])
}

model Revenu {
  id          Int      @id @default(autoincrement())
  date        DateTime
  montant     Float
  source      String
  description String?
  createdAt   DateTime @default(now())

  fermeId Int
  ferme   Ferme @relation(fields: [fermeId], references: [id])

  createdById Int
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])
}

model Prediction {
  id        Int      @id @default(autoincrement())
  type      String
  resultat  String
  confiance Float?
  date      DateTime @default(now())

  fermeId Int
  ferme   Ferme @relation(fields: [fermeId], references: [id])

  createdById Int
  createdBy   Utilisateur @relation(fields: [createdById], references: [id])

  conseils Conseil[]
}

model Conseil {
  id          Int      @id @default(autoincrement())
  description String
  date        DateTime

  predictionId Int
  prediction   Prediction @relation(fields: [predictionId], references: [id])
}

model Notification {
  id        Int                @id @default(autoincrement())
  titre     String
  message   String
  dateEnvoi DateTime           @default(now())
  statut    StatutNotification

  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
}

enum StatutPresence {
  PRESENT
  ABSENT
  MALADE
}

model Presence {
  id                Int            @id @default(autoincrement())
  date              DateTime       @default(now())
  statut            StatutPresence
  paye              Boolean        @default(false)
  certificatMedical String?        @db.Text

  utilisateurId     Int
  utilisateur       Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}
